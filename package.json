{
  "name": "roots",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "roots — the user-owned wallet on the dreamtree protocol",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 execute roots --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute roots --remote --file=migrations/0001_init.sql"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
